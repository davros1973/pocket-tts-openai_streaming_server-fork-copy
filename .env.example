# Docker environment configuration template
# Copy to .env and customize as needed

# Server settings
POCKET_TTS_PORT=49112
POCKET_TTS_LOG_LEVEL=INFO
POCKET_TTS_STREAM_DEFAULT=true

# Custom voices directory (mounted to container)
# POCKET_TTS_VOICES_DIR=./my_custom_voices

# Hugging Face token for voice cloning (optional)
# Get your token from: https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxxxxxxx

# LavaSR Audio Enhancement — bandwidth extension (24 kHz TTS → 48 kHz output)
# Model: YatharthS/LavaSR (Apache 2.0) — downloads ~150 MB from HuggingFace on first use.
# LAVASR_ENABLED=true            # set true to enable post-processing
# LAVASR_ENHANCE_DEFAULT=true    # apply BWE by default when enabled
# LAVASR_DENOISE_DEFAULT=false   # apply ULUNAS denoising (adds latency; for noisy input)
# LAVASR_MODEL=YatharthS/LavaSR  # HF model ID or absolute path to local snapshot
# LAVASR_DEVICE=cpu              # cpu (default) or cuda
